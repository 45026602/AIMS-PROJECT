# Cell 16: Plot 8 - Learning Curves (AUC vs Training Size)
# Generate learning curves by subsampling training data
train_sizes = np.linspace(0.1, 1.0, 10)
lc_sizes = train_sizes * len(X_train_normal_scaled)
lc_scores = {'IF': [], 'OC-SVM': [], 'LOF': [], 'HBOS': []}

for size_frac in train_sizes:
    n_samples = int(len(X_train_normal_scaled) * size_frac)
    X_sub = X_train_normal_scaled[:n_samples]
    
    # IF
    model_if = IsolationForest(contamination=best_cont_if, n_estimators=best_nest_if, max_samples=0.8, random_state=42)
    model_if.fit(X_sub)
    lc_scores['IF'].append(val_auc(model_if, X_val_scaled, y_val))
    
    # OC-SVM
    model_oc = OneClassSVM(nu=best_nu_oc, kernel='rbf', gamma=best_gamma_oc)
    model_oc.fit(X_sub)
    lc_scores['OC-SVM'].append(val_auc(model_oc, X_val_scaled, y_val))
    
    # LOF
    model_lof = LocalOutlierFactor(n_neighbors=best_nn_lof, contamination=contamination, novelty=True)
    model_lof.fit(X_sub)
    lof_sub_scores = -model_lof.score_samples(X_val_scaled)
    lc_scores['LOF'].append(roc_auc_score(y_val, lof_sub_scores))
    
    # HBOS
    if n_samples > X_sub.shape[1]:  # Ensure enough samples for cov
        cov_sub = np.cov(X_sub.T)
        try:
            inv_cov_sub = np.linalg.inv(cov_sub)
            mean_sub = np.mean(X_sub, axis=0)
            hbos_sub_val = np.array([mahalanobis(x, mean_sub, inv_cov_sub) for x in X_val_scaled])
            lc_scores['HBOS'].append(roc_auc_score(y_val, hbos_sub_val))
        except np.linalg.LinAlgError:
            lc_scores['HBOS'].append(np.nan)  # Skip if singular

fig, ax = plt.subplots(figsize=(8, 6))
for model in lc_scores:
    ax.plot(lc_sizes, lc_scores[model], marker='o', label=model)
ax.set_xlabel('Training Set Size')
ax.set_ylabel('Validation AUC')
ax.set_title('Learning Curves: Validation AUC vs Training Size (Churn Dataset)')
ax.legend()
plt.tight_layout()
plt.savefig(os.path.join(save_dir, 'learning_curves.png'), dpi=300, bbox_inches='tight')
plt.show()

